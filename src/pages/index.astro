---
import MainLayout from "@layouts/MainLayout.astro";
import Hero from "@components/sections/Hero.astro";
import ExperienceCard from "@components/ExperienceCard.astro";
import Skills from "@components/sections/Skills.astro";

const experiencias = [
    {
        company: "Secretaría de Planeación y Finanzas",
        role: "Senior Full Stack Developer",
        date: "2023 - Presente",
        description:
            "Liderazgo técnico en el desarrollo de Geoportales y sistemas de monitoreo estatal. Implementación de flujos CI/CD y optimización de servidores Linux.",
        tags: ["Astro", "Docker", "GIS", "PostgreSQL"],
    },
];
---

<MainLayout
    title="Carlos E. Méndez | Senior Software Engineer"
    description="Portafolio profesional de Carlos E. Méndez, Desarrollador de Software Senior con especialización en plataformas modernas basadas en la nube, arquitecturas escalables y aplicaciones web integrales."
>
    <Hero />

    <section id="experiencia" class="experience">
        <h2 class="experience__title">
            <span class="experience__number">01.</span> Experiencia Profesional
        </h2>
        <div class="experience__list">
            {experiencias.map((exp) => <ExperienceCard {...exp} />)}
        </div>
    </section>

    <Skills />
</MainLayout>
