---
import MainLayout from "@layouts/MainLayout.astro";
import Hero from "@components/sections/Hero.astro";
import ExperienceCard from "@components/ExperienceCard.astro";
import Skills from "@components/sections/Skills.astro";

const experiencias = [
    {
        company: "Secretaría de Planeación y Finanzas",
        role: "Senior Full Stack Developer",
        date: "2023 - Presente",
        description:
            "Liderazgo técnico en el desarrollo de Geoportales y sistemas de monitoreo estatal. Implementación de flujos CI/CD y optimización de servidores Linux.",
        tags: ["Astro", "Docker", "GIS", "PostgreSQL"],
    },
];
---

<MainLayout
    title="Carlos E. Méndez | Senior Software Engineer"
    description="Portafolio profesional de Carlos E. Méndez, Ingeniero de Software Senior con especialización en plataformas modernas basadas en la nube, arquitecturas escalables y aplicaciones web integrales. Enfocado en el desarrollo de productos digitales confiables desde su concepción hasta su producción."
>
    <Hero />

    <section id="experiencia" class="max-w-4xl mx-auto px-4 py-24">
        <h2 class="text-3xl font-bold mb-12 flex items-center gap-3">
            <span class="text-blue-600">01.</span> Experiencia Profesional
        </h2>
        <div class="space-y-4">
            {experiencias.map((exp) => <ExperienceCard {...exp} />)}
        </div>
    </section>

    <Skills />
</MainLayout>
