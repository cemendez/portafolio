---
interface Props {
    company: string;
    role: string;
    date: string;
    description: string;
    tags: string[];
}
const { company, role, date, description, tags } = Astro.props;
---

<div
    class="relative pl-8 pb-12 border-l border-gray-200 dark:border-gray-800 last:pb-0"
>
    <div
        class="absolute -left-[5px] top-0 w-2.5 h-2.5 bg-blue-600 rounded-full"
    >
    </div>
    <span class="text-sm font-bold text-blue-600 uppercase tracking-wider"
        >{date}</span
    >
    <h3 class="text-xl font-bold text-gray-900 dark:text-white mt-1">{role}</h3>
    <p class="text-lg font-medium text-gray-500 mb-4">{company}</p>
    <p class="text-gray-600 dark:text-gray-400 mb-4 leading-relaxed">
        {description}
    </p>
    <div class="flex flex-wrap gap-2">
        {
            tags.map((tag) => (
                <span class="px-3 py-1 bg-gray-100 dark:bg-gray-800 text-xs font-medium rounded-full text-gray-600 dark:text-gray-400">
                    {tag}
                </span>
            ))
        }
    </div>
</div>
