---
interface Props {
    company: string;
    role: string;
    date: string;
    description: string;
    tags: string[];
}
const { company, role, date, description, tags } = Astro.props;
---

<div class="experience-card">
    <div class="experience-card__dot"></div>
    <div class="experience-card__content">
        <span class="experience-card__date">
            <svg
                xmlns="http://www.w3.org/2000/svg"
                width="1em"
                height="1em"
                class="experience-card__date-icon"
                viewBox="0 0 24 24"
                ><g fill="none"
                    ><path
                        stroke="currentColor"
                        stroke-width="1.5"
                        d="M2 12c0-3.771 0-5.657 1.172-6.828S6.229 4 10 4h4c3.771 0 5.657 0 6.828 1.172S22 8.229 22 12v2c0 3.771 0 5.657-1.172 6.828S17.771 22 14 22h-4c-3.771 0-5.657 0-6.828-1.172S2 17.771 2 14z"
                    ></path><path
                        stroke="currentColor"
                        stroke-linecap="round"
                        stroke-width="1.5"
                        d="M7 4V2.5M17 4V2.5M2.5 9h19"></path><path
                        fill="currentColor"
                        d="M18 17a1 1 0 1 1-2 0a1 1 0 0 1 2 0m0-4a1 1 0 1 1-2 0a1 1 0 0 1 2 0m-5 4a1 1 0 1 1-2 0a1 1 0 0 1 2 0m0-4a1 1 0 1 1-2 0a1 1 0 0 1 2 0m-5 4a1 1 0 1 1-2 0a1 1 0 0 1 2 0m0-4a1 1 0 1 1-2 0a1 1 0 0 1 2 0"
                    ></path></g
                ></svg
            >
            {date}</span
        >
        <h3 class="experience-card__role">{role}</h3>
        <p class="experience-card__company">{company}</p>
        <p class="experience-card__description">
            {description}
        </p>
        <div class="experience-card__tags">
            {tags.map((tag) => <span class="experience-card__tag">{tag}</span>)}
        </div>
    </div>
</div>
